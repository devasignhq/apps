{
  "name": "devasign-frontend",
  "private": true,
  "packageManager": "npm@11.9.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:contributor": "turbo run dev --filter=@devasign/app-contributor",
    "dev:pm": "turbo run dev --filter=@devasign/app-pm",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check"
  },
  "devDependencies": {
    "turbo": "^2"
  }
}
